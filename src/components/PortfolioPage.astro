---
import type { PortfolioPageData } from '../data/portfolio';
import { siteConfig } from '../data/portfolio';

interface Props {
  page: PortfolioPageData;
}

const { page } = Astro.props as Props;
const { content, locale, switchHref } = page;
const currentYear = new Date().getFullYear();
const homeHref = page.cityId === 'gothenburg' ? page.path : locale === 'sv' ? '/sv/' : '/en/';
const switchLang = locale === 'sv' ? 'en' : 'sv';

const heroTitleHtml = locale === 'en'
  ? content.hero.title.replace('move fast', '<em>move fast</em>')
  : content.hero.title.replace('röra sig snabbt', '<em>röra sig snabbt</em>');

const contactIcon = (label: string) => {
  if (label === 'Email' || label === 'E-post') return '📧';
  if (label === 'LinkedIn') return 'in';
  return '📅';
};
---

<a class="skip-link" href="#main-content">{content.skipToContentLabel}</a>

<div class="page-shell">
  <header class="site-header">
    <div class="container nav-shell">
      <a class="brand" href={homeHref}>Anton Wester</a>

      <nav class="nav-links-wrap" aria-label={locale === 'sv' ? 'Primär navigation' : 'Primary navigation'}>
        <ul class="nav-links">
          {content.nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>

      <div class="nav-actions">
        <a class="locale-link" href={switchHref} hreflang={switchLang} lang={switchLang}>
          {content.localeSwitchLabel}
        </a>
        <a class="nav-cta" href={siteConfig.bookingLink} target="_blank" rel="noreferrer">
          {content.hero.primaryCta.label}
        </a>
      </div>
    </div>
  </header>

  <main id="main-content">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-orb hero-orb-1" aria-hidden="true"></div>
      <div class="hero-orb hero-orb-2" aria-hidden="true"></div>
      <div class="hero-orb hero-orb-3" aria-hidden="true"></div>

      <svg class="hero-grid-svg" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" preserveAspectRatio="none" aria-hidden="true">
        <defs>
          <pattern id="grid" width="80" height="80" patternUnits="userSpaceOnUse">
            <path d="M 80 0 L 0 0 0 80" fill="none" stroke="rgba(196,154,80,0.05)" stroke-width="1" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
        <line x1="0" y1="100%" x2="40%" y2="0"
          stroke="rgba(196,154,80,0.06)" stroke-width="1"
          stroke-dasharray="1000" stroke-dashoffset="1000"
          style="animation: draw-line 3s ease 0.8s both;" />
        <line x1="60%" y1="0" x2="100%" y2="60%"
          stroke="rgba(196,154,80,0.04)" stroke-width="1"
          stroke-dasharray="1000" stroke-dashoffset="1000"
          style="animation: draw-line 3s ease 1.2s both;" />
      </svg>

      <div class="hero-inner">
        <p class="hero-label">{content.hero.eyebrow}</p>
        <h1 id="hero-title" class="hero-headline" set:html={heroTitleHtml}></h1>
        <p class="hero-description">{content.hero.description}</p>

        <div class="hero-actions">
          <a class="btn-primary" href={siteConfig.bookingLink} target="_blank" rel="noreferrer">
            {content.hero.primaryCta.label} →
          </a>
          <a class="btn-ghost" href={content.hero.tertiaryCta.href}>
            {content.hero.tertiaryCta.label}
          </a>
          <a class="btn-ghost btn-cv" href="/anton-wester-resume.pdf" target="_blank" rel="noreferrer">
            {locale === 'sv' ? 'Ladda ner CV' : 'Download CV'}
          </a>
        </div>

        <dl class="hero-stats">
          {content.hero.metrics.map((metric) => (
            <div>
              <dt class="stat-label">{metric.label}</dt>
              <dd class="stat-value">{metric.value}</dd>
            </div>
          ))}
          <div>
            <dt class="stat-label">{content.availability.context}</dt>
            <dd class="stat-value stat-value-inline">
              <span class="avail-dot" aria-hidden="true"></span>{content.availability.label}
            </dd>
          </div>
        </dl>
      </div>

      <div class="ticker-wrap" aria-hidden="true">
        <div class="ticker-track">
          {[...content.tickerItems, ...content.tickerItems].map((item) => (
            <span class="ticker-item">
              {item}<span class="ticker-dot"></span>
            </span>
          ))}
        </div>
      </div>
    </section>

    <section id="local" class="section local-section" aria-labelledby="local-title">
      <div class="container local-grid">
        <div>
          <p class="section-label" data-reveal>{content.localLanding.eyebrow}</p>
          <h2 id="local-title" class="section-title" data-reveal>{content.localLanding.title}</h2>
          <p class="section-intro" data-reveal>{content.localLanding.intro}</p>
          <div class="local-copy" data-reveal>
            {content.localLanding.body.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </div>

        <aside class="local-panel" data-reveal aria-label={content.localLanding.highlightsTitle}>
          <h3 class="aside-title">{content.localLanding.highlightsTitle}</h3>
          <ul class="aside-list">
            {content.localLanding.highlights.map((highlight) => (
              <li>{highlight}</li>
            ))}
          </ul>
        </aside>
      </div>
    </section>

    <section id="services" class="section services-section" aria-labelledby="services-title">
      <div class="container">
        <p class="section-label" data-reveal>{content.services.eyebrow}</p>
        <h2 id="services-title" class="section-title" data-reveal>{content.services.title}</h2>
        <p class="section-intro" data-reveal>{content.services.description}</p>
        <ul class="services-grid" data-reveal>
          {content.services.items.map((service, index) => (
            <li>
              <article class="service-card">
                <div class="service-num">{String(index + 1).padStart(2, '0')}</div>
                <h3 class="service-title">{service.title}</h3>
                <p class="service-body">{service.body}</p>
                <div class="service-tags">
                  {service.outcomes.map((outcome, outcomeIndex) => (
                    <span class={outcomeIndex === service.outcomes.length - 1 ? 'tag tag-amber' : 'tag'}>{outcome}</span>
                  ))}
                </div>
              </article>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section id="work" class="section work-section" aria-labelledby="work-title">
      <div class="container">
        <p class="section-label" data-reveal>{content.projects.eyebrow}</p>
        <h2 id="work-title" class="section-title" data-reveal>{content.projects.title}</h2>
        <p class="section-intro" data-reveal>{content.projects.description}</p>
        <ul class="work-grid">
          {content.projects.items.map((project) => (
            <li>
              <article class="work-card" data-reveal>
                <p class="work-type">{project.label}</p>
                <h3 class="work-name">{project.name}</h3>
                <p class="work-desc">{project.summary}</p>
                <div class="work-meta">
                  {project.tags.map((tag) => (
                    <span class="tag-dark">{tag}</span>
                  ))}
                </div>
                <a class="work-link" href={project.href} target="_blank" rel="noreferrer">
                  {project.linkLabel} →
                </a>
                <p class="work-impact">{project.impact}</p>
              </article>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section id="experience" class="section experience-section" aria-labelledby="experience-title">
      <div class="container">
        <p class="section-label" data-reveal>{content.experience.eyebrow}</p>
        <h2 id="experience-title" class="section-title" data-reveal>{content.experience.title}</h2>
        <p class="section-intro" data-reveal>{content.experience.description}</p>
        <div class="experience-grid">
          <dl class="timeline" data-reveal>
            {content.experience.items.slice(0, Math.ceil(content.experience.items.length / 2)).map((item) => (
              <div class="timeline-item">
                <dt class="exp-period">{item.period}</dt>
                <dd class="exp-role">{item.role}</dd>
                <dd class="exp-company">{item.company}</dd>
                <dd class="exp-summary">{item.summary}</dd>
                <dd class="exp-tags">
                  {item.tags.map((tag) => (
                    <span class="tag-dark">{tag}</span>
                  ))}
                </dd>
              </div>
            ))}
          </dl>
          <dl class="timeline" data-reveal>
            {content.experience.items.slice(Math.ceil(content.experience.items.length / 2)).map((item) => (
              <div class="timeline-item">
                <dt class="exp-period">{item.period}</dt>
                <dd class="exp-role">{item.role}</dd>
                <dd class="exp-company">{item.company}</dd>
                <dd class="exp-summary">{item.summary}</dd>
                <dd class="exp-tags">
                  {item.tags.map((tag) => (
                    <span class="tag-dark">{tag}</span>
                  ))}
                </dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </section>

    <section id="faq" class="section faq-section" aria-labelledby="faq-title">
      <div class="container">
        <p class="section-label" data-reveal>{content.faq.eyebrow}</p>
        <h2 id="faq-title" class="section-title" data-reveal>{content.faq.title}</h2>
        <p class="section-intro" data-reveal>{content.faq.description}</p>
        <dl class="faq-list">
          {content.faq.items.map((item) => (
            <div class="faq-item" data-reveal>
              <dt class="faq-question">{item.question}</dt>
              <dd class="faq-answer">{item.answer}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <div class="section-transition" aria-hidden="true"></div>

    <section id="contact" class="section contact-section" aria-labelledby="contact-title">
      <div class="container">
        <div class="contact-inner">
          <div class="contact-side" data-reveal>
            <p class="section-label">{content.contact.eyebrow}</p>
            <h2 id="contact-title" class="contact-lead">{content.contact.title}</h2>
            <p class="contact-sub">{content.contact.description}</p>

            <address class="contact-address">
              <ul class="contact-options" role="list">
                {content.contact.directOptions.map((option) => (
                  <li>
                    <a
                      class="contact-option"
                      href={option.href}
                      target={option.href.startsWith('mailto:') ? undefined : '_blank'}
                      rel={option.href.startsWith('mailto:') ? undefined : 'noreferrer'}
                    >
                      <div class="contact-icon" aria-hidden="true">{contactIcon(option.label)}</div>
                      <div>
                        <span class="contact-label">{option.value}</span>
                        <span class="contact-detail">{option.note}</span>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </address>
          </div>

          <div data-reveal>
            <div class="contact-form-copy">
              <h3 class="contact-form-title">{content.contact.formTitle}</h3>
              <p class="contact-form-description">{content.contact.formDescription}</p>
            </div>

            <form
              class="contact-form"
              method="POST"
              action={`https://formsubmit.co/${siteConfig.email}`}
              data-portfolio-form
              data-success-message={content.contact.successMessage}
              data-error-message={content.contact.errorMessage}
              data-sending-message={content.contact.sendingLabel}
              data-submit-label={content.contact.submitLabel}
            >
              <input type="hidden" name="_subject" value={`Portfolio inquiry from ${content.cityName} page`} />
              <input type="hidden" name="_captcha" value="false" />
              <input class="sr-only" type="text" name="_honey" tabindex="-1" autocomplete="off" />

              <div class="form-field-grid">
                <label>
                  <span class="field-label">{content.contact.fields.name}</span>
                  <input id="name" name="name" autocomplete="name" placeholder={content.contact.placeholders.name} required />
                </label>
                <label>
                  <span class="field-label">{content.contact.fields.email}</span>
                  <input id="email" type="email" name="email" autocomplete="email" placeholder={content.contact.placeholders.email} required />
                </label>
              </div>

              <div class="form-field-grid">
                <label>
                  <span class="field-label">{content.contact.fields.company}</span>
                  <input id="company" name="company" autocomplete="organization" placeholder={content.contact.placeholders.company} />
                </label>
                <label>
                  <span class="field-label">{content.contact.fields.inquiry}</span>
                  <select id="inquiryType" name="inquiryType" required>
                    {content.contact.inquiryOptions.map((option) => (
                      <option value={option.value}>{option.label}</option>
                    ))}
                  </select>
                </label>
              </div>

              <label>
                <span class="field-label">{content.contact.fields.message}</span>
                <textarea id="message" name="message" rows="6" placeholder={content.contact.placeholders.message} required></textarea>
              </label>

              <div class="form-actions">
                <button class="btn-submit" type="submit">{content.contact.submitLabel}</button>
                <p class="form-status" data-form-status aria-live="polite"></p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-shell">
      <span class="footer-brand">© {currentYear} Anton Wester AB</span>
      <span class="footer-avail">
        <span class="footer-dot" aria-hidden="true"></span>
        {content.footer.availability}
      </span>
    </div>
  </footer>
</div>

<script is:inline>
  (() => {
    const header = document.querySelector('.site-header');
    if (!header) return;

    let lastScroll = 0;
    const handleScroll = () => {
      const currentScroll = window.scrollY;
      if (currentScroll <= 0) {
        header.classList.remove('is-hidden');
        return;
      }
      if (currentScroll > lastScroll && !header.classList.contains('is-hidden')) {
        header.classList.add('is-hidden');
      } else if (currentScroll < lastScroll && header.classList.contains('is-hidden')) {
        header.classList.remove('is-hidden');
      }
      lastScroll = currentScroll;
    };

    window.addEventListener('scroll', handleScroll, { passive: true });

    const revealTargets = document.querySelectorAll('[data-reveal]');
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
      );
      revealTargets.forEach((element) => observer.observe(element));
    } else {
      revealTargets.forEach((element) => element.classList.add('is-visible'));
    }

    document.querySelectorAll('[data-portfolio-form]').forEach((form) => {
      if (!(form instanceof HTMLFormElement)) {
        console.error('Expected portfolio form element to be an HTMLFormElement.');
        return;
      }

      if (!window.fetch || !window.FormData) {
        console.error('This browser does not support fetch or FormData for portfolio form submission.');
        return;
      }

      const status = form.querySelector('[data-form-status]');
      const submitButton = form.querySelector('button[type="submit"]');
      const submitLabel = form.dataset.submitLabel || (submitButton ? submitButton.textContent : 'Submit');
      const sendingLabel = form.dataset.sendingMessage || submitLabel;
      const successMessage = form.dataset.successMessage || '';
      const errorMessage = form.dataset.errorMessage || '';

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (status instanceof HTMLElement) {
          status.textContent = sendingLabel;
          status.dataset.state = 'sending';
        }

        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
          submitButton.textContent = sendingLabel;
        }

        try {
          const endpoint = form.action.replace('formsubmit.co/', 'formsubmit.co/ajax/');
          const response = await fetch(endpoint, {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: new FormData(form),
          });
          const result = await response.json();

          if (!response.ok || result.success === 'false') {
            throw new Error('Formsubmit request failed.');
          }

          form.reset();
          if (status instanceof HTMLElement) {
            status.textContent = successMessage;
            status.dataset.state = 'success';
          }
        } catch (error) {
          console.error('Portfolio form submission failed.', error);
          if (status instanceof HTMLElement) {
            status.textContent = errorMessage;
            status.dataset.state = 'error';
          }
        } finally {
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = false;
            submitButton.textContent = submitLabel;
          }
        }
      });
    });
  })();
</script>
